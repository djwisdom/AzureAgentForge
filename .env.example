# AzureAgentForge — Environment Variable Reference
# =========================================================
# Copy this file to .env and fill in real values for local development.
# In production, all secrets are injected from Azure Key Vault via
# Container App secret volume mounts. Never commit real values.
#
# ── LOCAL FULL STACK (no Azure) ──────────────────────────────────────────────
# `docker compose --profile full up` (or scripts/local-stack.sh up) runs the
# whole platform locally. It comes up healthy with NO credentials — every value
# has a working local default baked into docker-compose.yml, so copying this
# file to .env unchanged is enough to boot. To actually DRIVE agents, set ONE
# OpenAI-compatible endpoint (OPENAI_COMPAT_* below):
#   OpenAI:    OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1   OPENAI_COMPAT_API_KEY=sk-...
#   Ollama:    OPENAI_COMPAT_BASE_URL=http://host.docker.internal:11434/v1  OPENAI_COMPAT_API_KEY=ollama
#   LM Studio: OPENAI_COMPAT_BASE_URL=http://host.docker.internal:1234/v1   OPENAI_COMPAT_API_KEY=lm-studio
# See docs/local-development.md.

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=azure_foundry

# ── Azure AI Foundry — primary endpoint ──────────────────────────────────────
# Key Vault secrets: platform-azure-foundry-endpoint
#                    platform-azure-foundry-api-key
# These activate the gpt4o-mini (primary) tier in the model-router.
# Alternatively, set GPT4O_BASE_URL / GPT4O_API_KEY directly below.
# AZURE_FOUNDRY_ENDPOINT is aliased to GPT4O_BASE_URL in docker-compose.yml.
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=

# ── Model Router — primary tier (gpt4o-mini) direct vars ─────────────────────
# Optional: override the AZURE_FOUNDRY_* alias if the gpt-4o-mini deployment
# lives on a different endpoint than the rest of your Foundry project.
GPT4O_BASE_URL=
GPT4O_API_KEY=

# ── OpenAI-compatible router (local sidecar or upstream) ─────────────────────
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=

# ── Azure AI Foundry — grok-4-fast-reasoning (primary default model) ─────────
# Key Vault secrets: platform-azure-ai-foundry-grok4-uri-target
#                    platform-azure-ai-foundry-grok4-api-key
GROK_BASE_URL=
GROK_API_KEY=
GROK_MODEL=grok-4-fast-reasoning
GROK_DAILY_BUDGET_USD=
GROK_MAX_TOKENS=

# ── Azure AI Foundry — Phi-4 (budget fallback) ────────────────────────────────
# Key Vault secrets: platform-azure-ai-foundry-phi4-uri-target
#                    platform-azure-ai-foundry-phi4-api-key
PHI_BASE_URL=
PHI_API_KEY=
PHI_MODEL=Phi-4
PHI_DAILY_BUDGET_USD=
PHI_MAX_TOKENS=

# ── Azure AI Foundry — Kimi-K2.5 (complex coding) ────────────────────────────
# Key Vault secrets: platform-azure-ai-foundry-kimi-k25-uri-target
#                    platform-azure-ai-foundry-kimi-k25-api-key
KIMI_BASE_URL=
KIMI_API_KEY=
KIMI_MODEL=Kimi-K2.5
KIMI_DAILY_BUDGET_USD=
KIMI_MAX_TOKENS=

# ── Azure AI Foundry — Claude Sonnet 4.6 (reasoning / strategy) ──────────────
# Key Vault secrets: platform-azure-ai-foundry-sonnet46-uri-target
#                    platform-azure-ai-foundry-sonnet46-api-key
CLAUDE_BASE_URL=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_DAILY_BUDGET_USD=
CLAUDE_MAX_TOKENS=

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── Messaging / Bot surfaces ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ── Hermes Agent ──────────────────────────────────────────────────────────────
HONCHO_BASE_URL=
HONCHO_API_KEY=
HONCHO_APP_ID=
HERMES_HOME=
HERMES_DB_PATH=
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=

# ── Paperclip Orchestrator ────────────────────────────────────────────────────
# Key Vault secrets: platform-paperclip-db-url
#                    platform-paperclip-admin-email
#                    platform-paperclip-admin-password
DATABASE_URL=
PAPERCLIP_PUBLIC_URL=
PAPERCLIP_ALLOWED_HOSTNAMES=
PAPERCLIP_DEPLOYMENT_MODE=
PAPERCLIP_DEPLOYMENT_EXPOSURE=
PAPERCLIP_ADMIN_EMAIL=
PAPERCLIP_ADMIN_PASSWORD=

# ── Azure infrastructure ──────────────────────────────────────────────────────
AZURE_CLIENT_ID=
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_LEVEL=info
